; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hex Grid Tool"
config/description="A 3D hex grid editor with painting, snapping, and rotation support"
config/features=PackedStringArray("4.5", "Forward Plus")

[dotnet]

project/assembly_name="Hex Grid Tool"

[editor_plugins]

enabled=PackedStringArray("res://addons/MetaMultimeshInstance3D/plugin.cfg", "res://addons/hex_grid_editor/plugin.cfg", "res://addons/procedural_quad_godray/plugin.cfg", "res://addons/proton_scatter/plugin.cfg")

[filesystem]

import/blender/enabled=false

[rendering]

lights_and_shadows/directional_shadow/soft_shadow_filter_quality=4
lights_and_shadows/positional_shadow/soft_shadow_filter_quality.mobile=4
textures/default_filters/anisotropic_filtering_level=0

[shader_globals]

cloud_speed={
"type": "vec2",
"value": Vector2(0.01, 0.01)
}
cloud_scale={
"type": "float",
"value": 0.01
}
cloud_texture={
"type": "sampler2D",
"value": "res://addons/hex_grid_editor/textures/cloud_texture.tres"
}
cloud_strength={
"type": "float",
"value": 1.3
}
cel_cuts={
"type": "int",
"value": 8
}
