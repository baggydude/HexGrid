; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Hex Grid Tool"
config/description="A 3D hex grid editor with painting, snapping, and rotation support"
run/main_scene="res://demo_scene.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")

[dotnet]

project/assembly_name="Hex Grid Tool"

[editor_plugins]

enabled=PackedStringArray("res://addons/hex_grid_editor/plugin.cfg", "res://addons/proton_scatter/plugin.cfg")
